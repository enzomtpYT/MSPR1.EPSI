# ============================================
# MSPR1.EPSI - Environment Configuration
# ============================================

# ============================================
# DATABASE - PostgreSQL Configuration
# ============================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=etl_db

# ============================================
# RABBITMQ - Message Broker Configuration
# ============================================
RABBITMQ_DEFAULT_USER=rabbit
RABBITMQ_DEFAULT_PASS=rabbit_password

# ============================================
# DATABASE URL (for applications)
# ============================================
DATABASE_URL=postgresql://admin:password@database:5432/etl_db

# ============================================
# RABBITMQ URL (for applications)
# ============================================
RABBITMQ_URL=amqp://rabbit:rabbit_password@rabbitmq:5672/

# ============================================
# BACKEND - FastAPI Configuration
# ============================================
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=adminpassword123
DEFAULT_ADMIN_IS_ADMIN=true

# ============================================
# FRONTEND - Vue.js / Vite Configuration
# ============================================
VITE_API_URL=http://backend:8000/api/v0
VITE_APP_NAME=HealthAI Coach

# ============================================
# OPTIONAL - Development Settings
# ============================================
# NODE_ENV=development
# COMPOSE_PROJECT_NAME=mspr1-epsi
